# Ritual sovereign agent deploy config. Copy to .env and fill in.

# --- chain ---
RPC_URL=https://rpc.ritualfoundation.org
CHAIN_ID=1979

# --- deposit locked into the agent's RitualWallet, in wei (0.015 RITUAL = ~1 wake) ---
DEPOSIT_WEI=15000000000000000

# --- harness: 6 = ZeroClaw ---
CLI_TYPE=6

# --- Ritual's own LLM gateway: no external API key needed ---
MODEL=zai-org/GLM-4.7-FP8

# --- first prompt and a unique label per agent ---
PROMPT="Say hello world"
SALT=my-ritual-agent-1
